{
  "entities": {
    "Account": {
      "title": "Account",
      "description": "Financial account definition",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Asset", "Liability", "Equity"] }
      },
      "required": ["id", "name", "category"]
    },
    "TransactionItem": {
      "title": "Transaction Item",
      "description": "Main transaction category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "TransactionSubCategory": {
      "title": "Transaction Sub-Category",
      "description": "Transaction sub-category (remarks)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "A single financial transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "transactionItemId": { "type": "string" },
        "transactionItemName": { "type": "string" },
        "details": { "type": "string" },
        "customEntries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "accountId": { "type": "string" },
              "accountName": { "type": "string" },
              "accountCategory": { "type": "string", "enum": ["Asset", "Liability", "Equity"] },
              "amount": { "type": "number" },
              "type": { "type": "string", "enum": ["Dr", "Cr"] }
            }
          }
        },
        "remarksId": { "type": "string" },
        "remarks": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "date", "transactionItemId", "transactionItemName", "details", "customEntries", "remarksId", "remarks"]
    },
    "AppUser": {
      "title": "App User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "viewer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role", "createdAt"]
    },
    "Partner": {
      "title": "Partner",
      "description": "Partner for capital tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "ZakatSettings": {
      "title": "Zakat Settings",
      "description": "Settings for Zakat calculation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nisabAmount": { "type": "number" },
        "startDate": { "type": "string" }
      },
      "required": ["id", "nisabAmount", "startDate"]
    },
    "EntryHistory": {
      "title": "Entry History",
      "description": "Metadata for journal entry backups",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entryId": { "type": "string" },
        "action": { "type": "string", "enum": ["created", "updated", "deleted"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "storagePath": { "type": "string" }
      },
      "required": ["id", "entryId", "action", "timestamp", "storagePath"]
    },
    "Client": {
      "title": "Client",
      "description": "Client details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone", "company"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "serviceDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "paymentAccountId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Unpaid", "Partial", "Paid", "Carry Forward"] },
        "carriedToInvoiceNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "invoiceNumber", "clientId", "date", "totalAmount", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "method": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "invoiceId", "clientId", "amount", "date"]
    },
    "BankAccount": {
      "title": "Bank Account",
      "description": "Company bank account details for client payments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountTitleName": { "type": "string" },
        "accountName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "bankName": { "type": "string" },
        "branchName": { "type": "string" },
        "routingNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Employee official records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "fullName": { "type": "string" },
        "shortName": { "type": "string" },
        "mobileNo": { "type": "string" },
        "email": { "type": "string" },
        "nidNumber": { "type": "string" },
        "dateOfBirth": { "type": "string" },
        "gender": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "location": { "type": "string" },
        "emergencyPocName": { "type": "string" },
        "emergencyPocMobile": { "type": "string" },
        "relationshipWithPoc": { "type": "string" },
        "joiningDate": { "type": "string" },
        "startingSalary": { "type": "number" },
        "currentSalary": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "employeeId", "fullName", "joiningDate", "startingSalary", "currentSalary"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "AppUser",
      "description": "User profiles and roles"
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Pool of accounts"
    },
    "/transactionItems/{itemId}": {
      "schema": "TransactionItem",
      "description": "Pool of transaction items"
    },
    "/transactionSubCategories/{subId}": {
      "schema": "TransactionSubCategory",
      "description": "Pool of transaction sub-categories"
    },
    "/entries/{entryId}": {
      "schema": "LedgerEntry",
      "description": "Ledger transactions"
    },
    "/partners/{partnerId}": {
      "schema": "Partner",
      "description": "Pool of partners"
    },
    "/settings/{settingId}": {
      "schema": "ZakatSettings",
      "description": "Application settings"
    },
    "/entry_history/{historyId}": {
      "schema": "EntryHistory",
      "description": "Audit log and backup metadata for entries"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Clients list"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices list"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records"
    },
    "/bankAccounts/{accountId}": {
      "schema": "BankAccount",
      "description": "Company bank accounts"
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Employee records"
    }
  }
}
